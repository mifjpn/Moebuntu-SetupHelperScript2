#!/bin/bash
# Kawaiintu Setup Helper - Add Thunar

echo -e "\x1b[36;01m=========================================\x1b[39;49;00m"
echo -e "\x1b[36;01m         Installing Thunar               \x1b[39;49;00m"
echo -e "\x1b[36;01m=========================================\x1b[39;49;00m"

# 1. aptでのインストール
echo ">> Updating apt and installing Thunar..."
sudo apt update >/dev/null 2>&1
# 危険なワイルドカード (thunar*) を避け、必要なコアパッケージのみを明示指定します
sudo apt -y install thunar thunar-archive-plugin thunar-volman

# 2. Dock（お気に入り）への追加
echo ">> Adding Thunar to dock as favorite..."
FAVORITES=$(gsettings get org.gnome.shell favorite-apps)

if [[ "$FAVORITES" != *"'thunar.desktop'"* ]]; then
  # NautilusがDockにない場合でも失敗しないよう、配列の末尾に安全に追加するロジック
  NEW_FAVORITES=$(echo "$FAVORITES" | sed "s/]$/, 'thunar.desktop']/g" | sed "s/\[, /\[/g")
  gsettings set org.gnome.shell favorite-apps "$NEW_FAVORITES"
  echo ">> Thunar added to favorites."
else
  echo ">> Thunar is already in your favorites."
fi

# 3. カスタムアクション (uca.xml) の設定
echo ">> Configuring Thunar custom actions..."

UCA_DIR="$HOME/.config/Thunar"
UCA_FILE="$UCA_DIR/uca.xml"

# Thunarの設定ディレクトリが存在しなければ作成
mkdir -p "$UCA_DIR"

# uca.xmlが存在しない場合は、システムのデフォルトからコピーしてくる
if [ ! -e "$UCA_FILE" ]; then
  if [ -e "/etc/xdg/Thunar/uca.xml" ]; then
    cp /etc/xdg/Thunar/uca.xml "$UCA_FILE"
    echo ">> System default uca.xml copied."
  else
    # 万が一システムにデフォルトが存在しない場合のフォールバック（空のXMLを作成）
    echo "<?xml encoding=\"UTF-8\" version=\"1.0\"?><actions></actions>" > "$UCA_FILE"
    echo ">> Created new empty uca.xml."
  fi
fi

# カスタムアクションの挿入処理
if [ ! -e "${UCA_FILE}.bak" ]; then
  if [ -e "$UCA_FILE" ]; then
    echo ">> Injecting custom scripts into uca.xml..."
    cp "$UCA_FILE" "${UCA_FILE}.bak"
    
    # 確実に </actions> タグの直前にテキストファイルを挿入するための安全なawkコマンド
    awk '/<\/actions>/{system("cat ./thunar-execute-script.txt")}1' "${UCA_FILE}.bak" > "$UCA_FILE"
    
    echo ">> Custom actions configured."
  else
    echo ">> Error: uca.xml not found." # ここにはもう到達しないはずです
  fi
else
  echo ">> Custom actions already configured (backup exists)."
fi

echo ""
echo -n "Hit Any Key to return to menu: "
read -r -n 1 -s answer
echo ""

